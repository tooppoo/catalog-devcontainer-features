{
    "id": "git-utils",
    "version": "0.1.4",
    "name": "git-utils",
    "description": "Installs git-utils, some small git-sucommands",
    "documentationURL": "https://github.com/tooppoo/catalog-devcontainer-features/tree/main/src/git-utils",
    "licenseURL": "https://github.com/tooppoo/catalog-devcontainer-features/blob/main/LICENSE",
    "options": {
        "version": {
            "type": "string",
            "description": "git-utils release tag to install. Use latest to install the latest release.",
            "default": "latest"
        }
    },
    "installsAfter": [
        "ghcr.io/devcontainers/features/common-utils"
    ]
}
